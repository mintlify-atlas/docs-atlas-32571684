  "keyFeatures": [
    "Automated GitHub issue creation for scheduled Node.js team meetings",
    "HackMD meeting minutes document generation with collaborative editing",
    "iCal calendar integration for automatic meeting date detection",
    "Template-based customization for different Node.js working groups",
    "Agenda auto-population from labeled GitHub issues and PRs",
    "Dry-run mode for previewing output without side effects",
    "GitHub Actions integration for scheduled and manual workflow triggers",
    "Support for 20+ Node.js working groups and committees out of the box"
  ],
  "publicApiSurface": [
    "create-node-meeting-artifacts <group> [--dry-run] [--force] [--verbose]",
    "readMeetingConfig(config) -> MeetingConfig",
    "generateMeetingTitle(config, meetingConfig, meetingDate) -> string",
    "generateMeetingAgenda(agendaIssues) -> string",
    "generateMeetingIssue(config, meetingConfig, meetingDate, meetingAgenda, minutesDocLink) -> Promise<string>",
    "generateMeetingMinutes(config, meetingConfig, meetingTitle, meetingAgenda, minutesDocLink, githubIssueLink) -> Promise<string>",
    "createGitHubClient(config) -> Octokit",
    "getAgendaIssues(githubClient, config, meetingConfig) -> Promise<Record<string, GitHubIssue[]>>",
    "createOrUpdateGitHubIssue(githubClient, config, meetingConfig, title, content) -> Promise<GitHubIssue>",
    "createHackMDClient(config, meetingConfig) -> HackMDAPI",
    "getOrCreateMeetingNotesDocument(hackmdClient, title, config) -> Promise<HackMDNote>",
    "updateMeetingNotesDocument(hackmdClient, noteId, content) -> Promise<HackMDNote>",
    "getEventsFromCalendar(url) -> Promise<CalendarComponent[]>",
    "findNextMeetingDate(allEvents, meetingConfig) -> Promise<Date|null>"
  ]
}

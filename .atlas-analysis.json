{
  "projectType": "cli-tool",
  "projectName": "Node.js Meeting Artifacts Creator",
  "projectDescription": "A CLI tool that automates the creation of GitHub issues and HackMD meeting minutes documents for Node.js team meetings by reading calendar events and group templates.",
  "theme": "palm",
  "primaryColor": "#675ff1",
  "lightColor": "#4c4979",
  "darkColor": "#040405",
